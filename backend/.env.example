# ============================================================
# Calamiteiten App — Backend Omgevingsvariabelen
# Kopieer dit bestand naar .env en vul de waarden in.
# Commit NOOIT het .env bestand naar versiebeheer!
# ============================================================

# Server
NODE_ENV=development
PORT=3001

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAAM=calamiteiten_db
DB_GEBRUIKER=root
DB_WACHTWOORD=jouw_wachtwoord

# JWT
JWT_SECRET=vervang_dit_door_een_lang_willekeurig_geheim
JWT_VERLOOPTIJD=8h

# Bestandsopslag (uploads)
UPLOAD_MAP=uploads
MAX_BESTAND_GROOTTE_MB=10
