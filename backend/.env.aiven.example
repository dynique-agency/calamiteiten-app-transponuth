# .env.aiven.example — Kopieer dit naar .env.aiven en vul de Aiven-gegevens in.
# Dit bestand mag in git. Het echte .env.aiven NIET (staat in .gitignore).

AIVEN_HOST=mysql-xxxx-xxxx.k.aivencloud.com
AIVEN_PORT=21922
AIVEN_USER=avnadmin
AIVEN_PASSWORD=vervang_dit_door_jouw_aiven_wachtwoord
AIVEN_DATABASE=defaultdb
